# .env.example
# The secret key used to sign JWT tokens for authentication. 
# Generate a long random string for production.
JWT_SECRET=

# Database Connections (The app will prioritize PostgreSQL, then MySQL, then SQLite)
DATABASE_URL=postgres://user:password@host:port/dbname
MYSQL_URL=mysql://user:password@host:port/dbname

# Path to the SQLite database file (Fallback)
DB_PATH=./stego.db

# Gemini API Key for AI Image Generation
# Use MY_GEMINI_KEY to bypass platform reserved name restrictions
MY_GEMINI_KEY=
GEMINI_API_KEY=
